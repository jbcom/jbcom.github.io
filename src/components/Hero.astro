---
/**
 * Compact identity block — no display-type headline, no giant name. The
 * proof sentence is the hero; everything above it is just identity.
 * Statically rendered; the entrance is a CSS animation.
 */
import resume from '@/content/resume'

const { about } = resume
---

<section class="relative overflow-clip">
  <div class="hero-glow"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="hero-enter max-w-3xl">
      <p class="font-mono text-xs text-primary uppercase tracking-[0.2em]">{about.name}</p>

      <h1 class="font-heading text-3xl sm:text-4xl font-normal tracking-tight text-foreground mt-2">
        {about.label}
      </h1>

      <p class="text-base sm:text-lg text-foreground/85 leading-relaxed mt-5 max-w-2xl">
        {about.heroLine}
      </p>

      {
        about.stats && about.stats.length > 0 && (
          <dl class="flex flex-wrap items-stretch mt-10">
            {about.stats.map((stat, i) => (
              <div class={i === 0 ? 'pr-5 sm:pr-7 py-1' : 'border-l border-border px-5 sm:px-7 py-1'}>
                <dd class="font-heading text-3xl sm:text-4xl text-foreground leading-none">
                  {stat.value}
                </dd>
                <dt class="font-mono text-[0.65rem] uppercase tracking-wider text-muted-foreground mt-2">
                  {stat.label}
                </dt>
              </div>
            ))}
          </dl>
        )
      }

      <div class="flex items-center gap-2 mt-10 flex-wrap">
        <a href="/Jon_Bogaty_Resume.docx" download class="btn btn-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Download Résumé
        </a>
        <a href="/resume/" class="btn btn-outline">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          View Résumé
        </a>
        <div class="flex items-center gap-1 ml-1">
          <a
            href="https://github.com/jbcom"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="btn btn-ghost btn-icon"
          >
            <svg role="img" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a
            href="https://linkedin.com/in/jonbogaty"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="btn btn-ghost btn-icon"
          >
            <svg role="img" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          </a>
          <a
            href="https://t.me/jbpersonaldev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Telegram"
            class="btn btn-ghost btn-icon"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          </a>
        </div>
      </div>

      {about.status && (
        <p class="font-mono text-xs text-muted-foreground mt-8">{about.status.label}</p>
      )}
    </div>
  </div>
</section>
