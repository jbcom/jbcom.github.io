---
/**
 * Sticky anchor nav with scroll-spy. The spy is the only JavaScript on the
 * page — a dozen lines, inline, no framework. Hrefs are absolute so the
 * nav works from /writing/ pages too; the spy no-ops where sections are
 * absent. The Writing link surfaces only once a first post exists.
 */
import { getCollection } from 'astro:content'
import type { WritingEntry } from '@/content.config'
import resume from '@/content/resume'

const ANCHORS = [
  { id: 'open-source', label: 'Open Source' },
  { id: 'contact', label: 'Contact' },
] as const

const hasWriting = (await getCollection('writing', ({ data }: WritingEntry) => !data.draft)).length > 0
const onWriting = Astro.url.pathname.startsWith('/writing')
---

<header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 flex items-center gap-4 h-14">
    <a
      href="/#top"
      class="font-heading text-lg text-foreground shrink-0 hover:text-primary transition-colors"
    >
      {resume.about.name}
    </a>

    <nav class="flex items-center gap-1 sm:gap-2 flex-1 justify-end sm:justify-center overflow-x-auto scrollbar-hide">
      {
        ANCHORS.map((anchor) => (
          <a
            href={`/#${anchor.id}`}
            data-spy={anchor.id}
            class="nav-anchor relative px-2 sm:px-3 h-14 inline-flex items-center text-sm font-medium whitespace-nowrap transition-colors text-muted-foreground hover:text-foreground"
          >
            {anchor.label}
          </a>
        ))
      }
      {
        hasWriting && (
          <a
            href="/writing/"
            class:list={[
              'nav-anchor relative px-2 sm:px-3 h-14 inline-flex items-center text-sm font-medium whitespace-nowrap transition-colors text-muted-foreground hover:text-foreground',
              { active: onWriting },
            ]}
          >
            Writing
          </a>
        )
      }
    </nav>

    <a href="/Jon_Bogaty_Resume.docx" download class="btn btn-outline shrink-0 hidden sm:inline-flex">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Résumé
    </a>
  </div>
</header>

<style>
  .nav-anchor.active {
    color: var(--foreground);
  }
  .nav-anchor.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.5rem;
    right: 0.5rem;
    height: 2px;
    background: var(--primary);
  }
</style>

<script>
  const anchors = [...document.querySelectorAll<HTMLAnchorElement>('.nav-anchor')]
  const sections = anchors
    .map((a) => document.getElementById(a.dataset.spy ?? ''))
    .filter((el): el is HTMLElement => el !== null)

  function activate(id: string) {
    for (const a of anchors) a.classList.toggle('active', a.dataset.spy === id)
  }

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)
      if (visible[0]) activate(visible[0].target.id)
    },
    { rootMargin: '-20% 0px -60% 0px' }
  )
  for (const el of sections) observer.observe(el)

  // The footer (#contact) sits at the page bottom and never crosses the
  // observer's band — treat reaching the bottom as Contact being active.
  window.addEventListener(
    'scroll',
    () => {
      if (window.scrollY + window.innerHeight >= document.body.scrollHeight - 80) {
        activate('contact')
      }
    },
    { passive: true }
  )
</script>
