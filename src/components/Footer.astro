---
/**
 * Compact contact band — a plain email CTA, inline links, résumé buttons,
 * one-line education, and the live version stamp (the one good human touch).
 */
import resume from '@/content/resume'

const edu = resume.education[0]
const currentYear = new Date().getFullYear()
---

<footer id="contact" class="border-t border-border scroll-mt-14">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-12 space-y-8">
    <div>
      <h2 class="font-heading text-3xl text-foreground">Let's talk.</h2>
      <a
        href={`mailto:${resume.about.email}`}
        class="inline-block text-lg text-primary hover:text-primary/80 transition-colors mt-2"
      >
        {resume.about.email}
      </a>
    </div>

    <div class="flex items-center gap-x-6 gap-y-3 flex-wrap">
      {
        resume.about.profiles.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-muted-foreground hover:text-primary transition-colors"
          >
            {p.network} ↗
          </a>
        ))
      }
      <span class="flex items-center gap-2 ml-auto">
        <a href="/Jon_Bogaty_Resume.docx" download class="btn btn-outline">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Download Résumé
        </a>
        <a href="/resume/" class="btn btn-ghost">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          View
        </a>
      </span>
    </div>

    <div class="flex justify-between gap-4 flex-wrap text-xs text-muted-foreground">
      <span>
        {resume.about.location.city}, {resume.about.location.region} · open to remote
      </span>
      <span>
        {edu.studyType.replace(/ \(.*\)/, '')}, {edu.area} — {edu.institution} ({edu.endDate}), with
        honors
      </span>
    </div>

    <p class="font-mono text-[0.65rem] text-muted-foreground/70">
      © {currentYear} Jon Bogaty · v{__APP_VERSION__} · updated {__BUILD_DATE__}
    </p>
  </div>
</footer>
