---
const { title, subtitle } = Astro.props
---

<div class="flex">
  <div class="timeline-marker">
    <span class="mt-1 block size-4 rounded-full bg-primary"></span>
    <span class="block h-full w-px translate-x-[7px] bg-primary/40"></span>
  </div>
  <div class="min-w-0 px-5 pb-7">
    <h3 class="font-semibold text-base-content">{title}</h3>
    <p class="text-sm text-base-content/60">{subtitle}</p>
    <div class="my-2 text-sm leading-relaxed text-base-content/75">
      <slot />
    </div>
  </div>
</div>
