---
/**
 * Tri-panel of the three flagship projects with their real package tables —
 * the concrete artifact detail a résumé can't show. Color means category,
 * never decoration.
 */
import resume from '@/content/resume'
import type { ProjectCategory } from '@/content/resume'

const CATEGORY_ACCENT: Record<ProjectCategory, string> = {
  security: 'var(--brand-amber)',
  agents: 'var(--brand-steel)',
  data: 'var(--brand-success)',
  '3d': 'var(--brand-purple)',
}
---

<section id="open-source" class="mx-auto max-w-5xl px-4 sm:px-6 py-14 scroll-mt-14">
  <h2 class="font-heading text-3xl text-foreground mb-8">Open Source</h2>

  <div class="space-y-10">
    <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
      {resume.about.summary[1]}
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-x-10 gap-y-10">
      {
        resume.projects.map((project) => {
          const accent = CATEGORY_ACCENT[project.category]
          return (
            <article
              class="border-l-2 pl-5 sm:pl-6 py-1 flex flex-col"
              style={`border-color: ${accent}`}
            >
              <div class="flex items-baseline justify-between gap-3">
                <h3 class="font-heading text-2xl text-foreground">
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-primary transition-colors"
                  >
                    {project.name}
                  </a>
                </h3>
                {project.domain && (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-[0.65rem] text-muted-foreground hover:text-primary transition-colors shrink-0 inline-flex items-center gap-1"
                  >
                    {project.domain}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  </a>
                )}
              </div>

              <p class="font-mono text-xs uppercase tracking-wider mt-1" style={`color: ${accent}`}>
                {project.tagline}
              </p>

              <p class="text-sm text-muted-foreground leading-relaxed mt-3">{project.description}</p>

              {project.packages && (
                <dl class="mt-4">
                  {project.packages.map((pkg) => (
                    <div class="py-1.5 border-b border-border/50 last:border-0">
                      <dt>
                        <code class="font-mono text-xs text-foreground">{pkg.name}</code>
                      </dt>
                      <dd class="text-xs text-muted-foreground mt-0.5">{pkg.description}</dd>
                    </div>
                  ))}
                </dl>
              )}

              {project.tech && (
                <p class="font-mono text-[0.7rem] text-muted-foreground/80 mt-auto pt-4">
                  {project.tech.join(' · ')}
                </p>
              )}
            </article>
          )
        })
      }
    </div>
  </div>
</section>
