---
import HorizontalCard from '@/components/HorizontalCard.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import resume from '@/content/resume'
---

<BaseLayout title={`Projects · ${resume.about.name}`} sideBarActiveItemID="projects">
  <section class="mb-10">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-primary">Open-source portfolio</p>
    <h1 class="mt-3 text-4xl font-bold text-base-content">Projects</h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-base-content/70">
      These are the public artifacts that make the resume less abstract: shipped tools, package
      surfaces, release systems, and implementation details you can inspect.
    </p>
  </section>

  <div class="grid gap-1">
    {
      resume.projects.map((project) => (
        <section id={project.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
          <HorizontalCard
            title={project.name}
            img={project.image}
            desc={project.description}
            url={project.url}
            badge={project.category}
            tags={project.tech}
            meta={project.domain}
          />
          {project.packages && (
            <div class="ml-0 border-l border-base-300 px-5 pb-7 pt-1 md:ml-[15rem]">
              <h2 class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-primary">
                Package surface
              </h2>
              <dl class="grid gap-3">
                {project.packages.map((pkg) => (
                  <div class="rounded-md bg-base-200 p-3">
                    <dt>
                      <code class="font-mono text-sm text-base-content">{pkg.name}</code>
                    </dt>
                    <dd class="mt-1 text-sm text-base-content/65">{pkg.description}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
          <div class="divider my-0"></div>
        </section>
      ))
    }
  </div>
</BaseLayout>
