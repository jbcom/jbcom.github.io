---
import BaseLayout from '@/layouts/BaseLayout.astro'
import resume from '@/content/resume'
import { operatingPrinciples, outcomeStories } from '@/content/site'

const services = [
  {
    title: 'Platform and DevOps audit',
    body: 'Map the real state of cloud accounts, CI/CD, Terraform, secrets, observability, incident response, and ownership boundaries.',
  },
  {
    title: 'Cloud cost reduction',
    body: 'Find the high-leverage waste: serverless migration candidates, idle capacity, right-sizing, storage churn, and missing guardrails.',
  },
  {
    title: 'Terraform and automation systems',
    body: 'Build maintainable infrastructure workflows, provider abstractions, CI gates, and internal tooling that teams can keep using.',
  },
  {
    title: 'SRE and reliability foundations',
    body: 'Establish monitoring, alerting, runbooks, release safety, and incident practices without turning a small team into a process shop.',
  },
]
---

<BaseLayout title={`Services · ${resume.about.name}`} sideBarActiveItemID="services">
  <section class="mb-10">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-primary">Independent consulting</p>
    <h1 class="mt-3 text-4xl font-bold text-base-content">Platform work for teams that need leverage.</h1>
    <p class="mt-5 max-w-3xl text-base leading-relaxed text-base-content/70">
      I am useful where infrastructure, delivery, security operations, and cost control are tangled
      together. The work is making ownership visible, removing repeated coordination, and leaving teams
      with a platform they can operate without turning one person into the bottleneck.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="btn btn-primary" href={`mailto:${resume.about.email}`}>Start a conversation</a>
      <a class="btn btn-outline" href="/contributor">Contributor profile</a>
      <a class="btn btn-outline" href="/cv">Read the CV</a>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    {
      services.map((service) => (
        <article class="rounded-lg border border-base-300 bg-base-100 p-5">
          <h2 class="text-xl font-bold text-base-content">{service.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-base-content/70">{service.body}</p>
        </article>
      ))
    }
  </section>

  <section class="mt-10 rounded-lg border border-base-300 bg-base-200 p-6">
    <h2 class="text-2xl font-bold text-base-content">What good looks like</h2>
    <ul class="mt-4 grid gap-3 text-sm leading-relaxed text-base-content/70 md:grid-cols-3">
      <li>Cloud spend tied to architecture and usage, not spreadsheet cleanup.</li>
      <li>Infrastructure changes flowing through maintained tools instead of repeated handoffs.</li>
      <li>Security, reliability, and delivery standards embedded in the way teams ship.</li>
    </ul>
  </section>

  <section class="mt-10">
    <div class="mb-4 flex items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">Related outcomes</p>
        <h2 class="mt-1 text-3xl font-bold text-base-content">Why the services exist</h2>
      </div>
      <a href="/outcomes" class="link-hover text-sm text-primary">Outcomes</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {
        outcomeStories.slice(0, 4).map((story) => (
          <a
            href={`/outcomes#${story.slug}`}
            class="rounded-lg border border-base-300 bg-base-100 p-5 transition hover:bg-base-200"
          >
            <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-primary">
              {story.eyebrow}
            </p>
            <h3 class="mt-2 text-lg font-bold text-base-content">{story.title}</h3>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-10">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">Working model</p>
    <h2 class="mt-1 text-3xl font-bold text-base-content">How I approach the work</h2>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      {
        operatingPrinciples.map((principle) => (
          <article class="rounded-lg border border-base-300 bg-base-100 p-5">
            <h3 class="text-lg font-bold text-base-content">{principle.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-base-content/70">{principle.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
