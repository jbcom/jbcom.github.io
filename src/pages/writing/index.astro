---
import { getCollection } from 'astro:content'
import type { WritingEntry } from '../../content.config'
import BaseLayout from '../../layouts/BaseLayout.astro'

const posts = (await getCollection('writing', ({ data }: WritingEntry) => !data.draft)).sort(
  (a: WritingEntry, b: WritingEntry) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---

<BaseLayout title="Writing · Jon Bogaty" sideBarActiveItemID="writing">
  <section class="mb-10">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-primary">Notes and case studies</p>
    <h1 class="mt-3 text-4xl font-bold text-base-content">Writing</h1>
  </section>
      {
        posts.length === 0 ? (
          <p class="max-w-2xl text-sm leading-relaxed text-base-content/70">
            No public posts are published yet. The CV and projects pages are the canonical proof
            surfaces while longer case studies are being pulled into the site.
          </p>
        ) : (
          <ul class="space-y-6">
            {posts.map((post: WritingEntry) => (
              <li>
                <a href={`/writing/${post.id}/`} class="group block">
                  <h2 class="text-xl font-bold text-base-content transition-colors group-hover:text-primary">
                    {post.data.title}
                  </h2>
                  <p class="mt-1 font-mono text-[0.65rem] uppercase tracking-wider text-base-content/50">
                    {formatDate(post.data.pubDate)}
                  </p>
                  <p class="mt-2 text-sm leading-relaxed text-base-content/70">
                    {post.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        )
      }
</BaseLayout>
