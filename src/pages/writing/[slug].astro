---
import { getCollection, render } from 'astro:content'
import type { WritingEntry } from '../../content.config'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }: WritingEntry) => !data.draft)
  return posts.map((post: WritingEntry) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props as { post: WritingEntry }
const { Content } = await render(post)

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })
---

<BaseLayout title={`${post.data.title} · Jon Bogaty`} description={post.data.description} sideBarActiveItemID="writing">
  <article class="max-w-3xl">
    <header class="mb-8">
          <p class="font-mono text-[0.65rem] uppercase tracking-wider text-base-content/50">
            {formatDate(post.data.pubDate)}
            {post.data.updatedDate && ` · updated ${formatDate(post.data.updatedDate)}`}
          </p>
          <h1 class="mt-2 text-3xl font-bold text-base-content sm:text-4xl">
            {post.data.title}
          </h1>
        </header>
        <div class="post-body">
          <Content />
        </div>
  </article>
  <p class="mt-12">
        <a href="/writing/" class="text-sm text-primary transition-colors hover:text-primary/80">
          ← All writing
        </a>
      </p>
</BaseLayout>

<style is:global>
  /* Minimal prose styling in the site's voice — no typography plugin. */
  .post-body {
    color: var(--color-base-content);
    line-height: 1.7;
    font-size: 1rem;
  }
  .post-body p,
  .post-body ul,
  .post-body ol,
  .post-body pre,
  .post-body blockquote {
    margin-bottom: 1rem;
  }
  .post-body h2,
  .post-body h3 {
    font-family: var(--font-heading);
    color: var(--color-base-content);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-body h2 { font-size: 1.5rem; }
  .post-body h3 { font-size: 1.25rem; }
  .post-body a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-body code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-base-200);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
  .post-body pre {
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }
  .post-body pre code {
    background: none;
    padding: 0;
  }
  .post-body ul { list-style: disc; padding-left: 1.5rem; }
  .post-body ol { list-style: decimal; padding-left: 1.5rem; }
  .post-body blockquote {
    border-left: 2px solid var(--brand-amber);
    padding-left: 1rem;
    color: color-mix(in srgb, var(--color-base-content) 70%, transparent);
  }
</style>
