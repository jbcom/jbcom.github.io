---
/**
 * Print-optimized resume page.
 * Rendered as static HTML by Astro — zero JavaScript.
 * Pandoc converts this to PDF and DOCX during the build.
 */
import resume from '@/content/resume.json'
import { formatDateRange } from '@/lib/dates'

const CLOUD_TECH = new Set(['AWS', 'GCP', 'Azure'])

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{resume.about.name} - Resume</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: 'Inter', -apple-system, 'Segoe UI', sans-serif;
        font-size: 9.5pt;
        line-height: 1.4;
        color: #1a1a1a;
        padding: 0;
      }

      .header { text-align: center; margin-bottom: 12pt; }
      .header h1 { font-size: 20pt; font-weight: 700; color: #0B0D14; margin-bottom: 2pt; }
      .header .label { font-size: 9pt; color: #996B1D; margin-bottom: 4pt; }
      .header .contact { font-size: 8pt; color: #555; }
      .header .contact a { color: #6B8BAD; text-decoration: none; }

      h2 {
        font-size: 10.5pt;
        font-weight: 700;
        color: #0B0D14;
        text-transform: uppercase;
        letter-spacing: 0.5pt;
        border-bottom: 1.5pt solid #996B1D;
        padding-bottom: 3pt;
        margin-top: 12pt;
        margin-bottom: 6pt;
      }

      .summary { font-size: 9pt; line-height: 1.45; margin-bottom: 4pt; }

      .job { margin-bottom: 8pt; }
      .job-header { display: flex; justify-content: space-between; align-items: baseline; }
      .job-title { font-weight: 700; font-size: 10pt; color: #0B0D14; }
      .job-dates { font-size: 8.5pt; color: #996B1D; white-space: nowrap; }
      .job-company { font-style: italic; font-size: 9pt; color: #444; margin-bottom: 3pt; }
      .job-summary { font-size: 8.5pt; color: #333; margin-bottom: 3pt; }
      .job-departure { font-size: 8pt; color: #555; font-style: italic; margin-top: 2pt; }

      ul { padding-left: 14pt; margin-bottom: 2pt; }
      li { font-size: 8.5pt; line-height: 1.35; margin-bottom: 2pt; }
      li::marker { color: #996B1D; }

      .earlier-pos { display: flex; justify-content: space-between; font-size: 8.5pt; margin-bottom: 1pt; }
      .earlier-pos .role { font-weight: 600; }
      .earlier-pos .year { color: #996B1D; }

      .skills-cat { margin-bottom: 3pt; font-size: 8.5pt; }
      .skills-cat strong { color: #0B0D14; }

      .education .degree { font-weight: 700; font-size: 9.5pt; }
      .education .school { font-size: 8.5pt; color: #444; }
      .education .honors { font-style: italic; font-size: 8.5pt; color: #996B1D; }

      .project { margin-bottom: 6pt; }
      .project-name { font-weight: 700; font-size: 9.5pt; color: #0B0D14; }
      .project-tagline { font-size: 8.5pt; color: #996B1D; font-style: italic; }
      .project-desc { font-size: 8.5pt; line-height: 1.35; margin-top: 1pt; }

      .sitenav {
        position: sticky;
        top: 0;
        background: #fff;
        border-bottom: 1px solid #ddd;
        padding: 8pt 16pt;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 9pt;
        margin-bottom: 12pt;
      }
      .sitenav a { color: #6B8BAD; text-decoration: none; font-weight: 500; }
      .sitenav a:hover { color: #996B1D; }
      .sitenav .downloads { display: flex; gap: 12pt; }

      @media print {
        body { padding: 0; }
        @page { margin: 0.5in; size: letter; }
        .sitenav { display: none; }
        .tech-chips { display: none; }
      }

      .tech-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4pt;
        margin-top: 2pt;
        margin-bottom: 3pt;
      }
      .tech-chip {
        font-size: 7.5pt;
        padding: 1pt 5pt;
        border: 1px solid #ddd;
        border-radius: 3pt;
        color: #555;
        background: #fafafa;
      }
      .tech-chip.cloud {
        background: #fff7e6;
        border-color: #996B1D;
        color: #996B1D;
      }
    </style>
  </head>
  <body>
    <nav class="sitenav">
      <a href="/">&larr; jonbogaty.com</a>
      <div class="downloads">
        <a href="/Jon_Bogaty_Resume.pdf" download>Download PDF</a>
        <a href="/Jon_Bogaty_Resume.docx" download>Download DOCX</a>
      </div>
    </nav>
    <div class="header">
      <h1>{resume.about.name}</h1>
      <div class="label">{resume.about.label}</div>
      <div class="contact">
        {resume.about.location.city}, {resume.about.location.region} &nbsp;|&nbsp;
        <a href={`mailto:${resume.about.email}`}>{resume.about.email}</a> &nbsp;|&nbsp;
        <a href={resume.about.url}>{resume.about.url}</a>
        {resume.about.profiles.map((p) => (
          <Fragment>
            &nbsp;|&nbsp; <a href={p.url}>{p.url}</a>
          </Fragment>
        ))}
      </div>
    </div>

    {resume.about.tagline && (
      <p class="summary" style="text-align:center;font-style:italic;color:#996B1D;margin-bottom:8pt">
        {resume.about.tagline}
      </p>
    )}

    <h2>Professional Summary</h2>
    {(Array.isArray(resume.about.summary) ? resume.about.summary : [resume.about.summary]).map(
      (text) => <p class="summary">{text}</p>
    )}

    <h2 id="projects">Featured Open-Source Projects</h2>
    {resume.projects.slice(0, 5).map((project) => (
      <div class="project" id={slugify(project.name)}>
        <div class="project-name">{project.name}{project.domain && ` — ${project.domain}`}</div>
        {project.tagline && <div class="project-tagline">{project.tagline}</div>}
        <div class="project-desc">{project.description}</div>
      </div>
    ))}

    <h2 id="experience">Professional Experience</h2>
    {resume.work.map((job) => (
      <div class="job" id={slugify(job.name)}>
        <div class="job-header">
          <span class="job-title">{job.position}</span>
          <span class="job-dates">{formatDateRange(job.startDate, job.endDate)}</span>
        </div>
        <div class="job-company">{job.name}</div>
        {job.tech && job.tech.length > 0 && (
          <div class="tech-chips">
            {job.tech.map((t) => (
              <span class={`tech-chip${CLOUD_TECH.has(t) ? ' cloud' : ''}`}>{t}</span>
            ))}
          </div>
        )}
        {job.summary && <div class="job-summary">{job.summary}</div>}
        {job.highlights?.length ? (
          <ul>
            {job.highlights.map((h) => (
              <li>{h}</li>
            ))}
          </ul>
        ) : null}
        {job.departureContext && <div class="job-departure">{job.departureContext}</div>}
      </div>
    ))}

    <h2>Earlier Career</h2>
    <p class="summary" style="margin-bottom:4pt">{resume.earlierCareer.summary}</p>
    {resume.earlierCareer.positions.map((pos) => (
      <div class="earlier-pos">
        <span>
          <span class="role">{pos.position}</span> &mdash; {pos.name}
        </span>
        <span class="year">{pos.year}</span>
      </div>
    ))}

    <h2>Technical Skills</h2>
    {resume.skills.map((cat) => (
      <div class="skills-cat">
        <strong>{cat.name}:</strong> {cat.keywords.join(', ')}
      </div>
    ))}

    <h2>Education</h2>
    {resume.education.map((edu) => (
      <div class="education">
        <div class="degree">{edu.studyType} &mdash; {edu.area}</div>
        <div class="school">{edu.institution} | {edu.startDate}&ndash;{edu.endDate}</div>
        {edu.honors && <div class="honors">{edu.honors.join(' \u2022 ')}</div>}
      </div>
    ))}
  </body>
</html>
