---
import BaseLayout from '@/layouts/BaseLayout.astro'
import resume from '@/content/resume'
import { operatingPrinciples, outcomeStories } from '@/content/site'
---

<BaseLayout title={`Outcomes · ${resume.about.name}`} sideBarActiveItemID="outcomes">
  <section class="mb-10">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-primary">Proof beyond the resume</p>
    <h1 class="mt-3 text-4xl font-bold text-base-content">Outcomes</h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-base-content/70">
      The CV gives the chronology. Projects show public artifacts. These outcome stories connect the
      two: what changed, what systems were built, and why the work is senior platform work rather than
      a list of tools.
    </p>
  </section>

  <section class="grid gap-5">
    {
      outcomeStories.map((story) => (
        <article id={story.slug} class="rounded-lg border border-base-300 bg-base-100 p-5">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-primary">{story.eyebrow}</p>
          <h2 class="mt-2 text-2xl font-bold text-base-content">{story.title}</h2>
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-base-content/70">{story.summary}</p>
          <div class="mt-5 grid gap-3 md:grid-cols-3">
            {story.proof.map((item) => (
              <p class="rounded-md bg-base-200 p-3 text-sm leading-relaxed text-base-content/75">
                {item}
              </p>
            ))}
          </div>
          <div class="mt-5 flex flex-wrap gap-2">
            {story.complements.map((link) => (
              <a href={link.href} class="btn btn-outline btn-sm">
                {link.label}
              </a>
            ))}
          </div>
        </article>
      ))
    }
  </section>

  <section class="mt-10">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-primary">Operating model</p>
    <h2 class="mt-2 text-3xl font-bold text-base-content">How the work tends to get stronger</h2>
    <div class="mt-5 grid gap-4 md:grid-cols-2">
      {
        operatingPrinciples.map((principle) => (
          <article class="rounded-lg border border-base-300 bg-base-200 p-5">
            <h3 class="text-lg font-bold text-base-content">{principle.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-base-content/70">{principle.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
