{
  "name": "jbcom.github.io",
  "version": "1.6.0",
  "description": "Jon Bogaty's professional portfolio and jbcom ecosystem showcase",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "resume:build": "tsx scripts/resume/build-docx.ts",
    "resume:qc": "tsx scripts/resume/qc.ts",
    "generate:og": "tsx scripts/generate-og-image.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "astro check && tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "astro": "^6.4.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@turbodocx/html-to-docx": "^1.21.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jszip": "^3.10.1",
    "playwright": "^1.60.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "homepage": "https://www.jonbogaty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbcom/jbcom.github.io.git"
  },
  "author": "Jon Bogaty <jon@jonbogaty.com>",
  "license": "MIT",
  "keywords": [
    "portfolio",
    "jbcom",
    "astro",
    "react",
    "shadcn",
    "github-pages",
    "resume"
  ]
}
