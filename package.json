{
  "name": "jbcom.github.io",
  "version": "1.5.0",
  "description": "Jon Bogaty's professional portfolio and jbcom ecosystem showcase",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "resume:build": "tsx scripts/resume/build-docx.ts",
    "resume:qc": "tsx scripts/resume/qc.ts",
    "generate:og": "tsx scripts/generate-og-image.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "astro sync && astro check && tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^6.4.5",
    "daisyui": "^5.5.23"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@turbodocx/html-to-docx": "^1.21.0",
    "@types/node": "^25.0.3",
    "jszip": "^3.10.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "homepage": "https://www.jonbogaty.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbcom/jbcom.github.io.git"
  },
  "author": "Jon Bogaty <jon@jonbogaty.com>",
  "license": "MIT",
  "keywords": [
    "portfolio",
    "jbcom",
    "astro",
    "github-pages",
    "resume"
  ]
}
